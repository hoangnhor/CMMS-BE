# Runtime mode: development | production
NODE_ENV=development

# API port
PORT=5000

# MongoDB connection string (local example)
MONGO_URI=mongodb://localhost:27017/asset_management

# JWT signing secret (production: >= 32 chars)
JWT_SECRET=replace_with_a_strong_32_plus_chars_secret
JWT_EXPIRES_IN=7d
REFRESH_JWT_SECRET=replace_with_a_different_strong_32_plus_chars_secret
REFRESH_JWT_EXPIRES_IN=30d

# Comma-separated origins or single origin
FRONTEND_ORIGIN=http://localhost:5173

# Cron for PM checker (default 06:00 daily)
PM_CHECK_CRON=0 6 * * *

# Optional system user id for automation jobs
SYSTEM_USER_ID=

# Enable when behind reverse proxy (Render/Nginx)
TRUST_PROXY=false

# Request body JSON size limit
JSON_LIMIT=1mb

# Global rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600

# Auth/login rate limit
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# Graceful shutdown timeout (ms)
SHUTDOWN_TIMEOUT_MS=10000

# Optional Redis for distributed rate-limit (recommended for production)
REDIS_URL=
REDIS_PREFIX=am:rl
